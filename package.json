{
  "name": "netdash-toolkit",
  "version": "3.0.1",
  "private": true,
  "description": "Professional network engineering toolkit with real networking capabilities - featuring subnet calculations, VLSM planning, VLAN management, real ICMP ping, traceroute, and port scanning",
  "author": {
    "name": "Sunny Patel",
    "email": "sunnypatel124555@gmail.com",
    "url": "https://github.com/sunnypatell"
  },
  "license": "MIT",
  "homepage": "https://netdash-toolkit.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnypatell/netdash-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/sunnypatell/netdash-toolkit/issues"
  },
  "keywords": [
    "network",
    "networking",
    "subnet",
    "calculator",
    "vlsm",
    "vlan",
    "ping",
    "traceroute",
    "port-scanner",
    "dns",
    "electron",
    "nextjs",
    "typescript",
    "network-tools",
    "network-engineering",
    "it-tools",
    "devops"
  ],
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "@tailwindcss/oxide",
      "electron-winstaller"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development next dev\" \"wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .\"",
    "electron:build": "next build && tsc -p electron/tsconfig.json && electron-builder",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "dist:mac": "pnpm electron:build --mac",
    "dist:win": "pnpm electron:build --win",
    "dist:linux": "pnpm electron:build --linux",
    "dist:all": "pnpm electron:build --mac --win --linux",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "1.2.14",
    "@radix-ui/react-alert-dialog": "1.1.17",
    "@radix-ui/react-aspect-ratio": "1.1.10",
    "@radix-ui/react-avatar": "1.2.0",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "1.1.14",
    "@radix-ui/react-context-menu": "2.3.1",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-hover-card": "1.1.17",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "1.1.18",
    "@radix-ui/react-navigation-menu": "1.2.16",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "1.4.1",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "1.4.1",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "1.3.1",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "1.2.17",
    "@radix-ui/react-toggle": "1.1.12",
    "@radix-ui/react-toggle-group": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.10",
    "@vercel/analytics": "2.0.1",
    "autoprefixer": "^10.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "firebase": "^12.15.0",
    "geist": "^1.7.2",
    "input-otp": "1.4.2",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "next-themes": "latest",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-day-picker": "10.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.9.0",
    "serve-handler": "^6.1.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/serve-handler": "^6.1.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "39.8.10",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "^6",
    "wait-on": "^9.0.10"
  }
}
